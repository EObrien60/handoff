{
  "name": "@handoff/sdk",
  "version": "0.1.0",
  "description": "Dashboarding SDK for Handoff — a typed, auth-agnostic API client plus self-styled React dashboard primitives.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19",
    "typescript": "^5"
  },
  "keywords": ["dashboard", "sdk", "react", "handoff", "typescript"],
  "license": "MIT"
}
